{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/handler.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/handler" },
    { "source": "/blog/:slug", "destination": "/blog/:slug/index.html" },
    { "source": "/services", "destination": "/services/index.html" },
    { "source": "/pricing", "destination": "/pricing/index.html" },
    { "source": "/contact", "destination": "/contact/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
